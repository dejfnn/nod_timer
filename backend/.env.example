# Postgres connection string (Railway provides this automatically as DATABASE_URL)
DATABASE_URL="postgresql://user:password@localhost:5432/timeflow?schema=public"

# Secret used to sign JWT access tokens (use a long random string in production)
JWT_SECRET="change-me-to-a-long-random-secret"

# Comma-separated list of allowed CORS origins (the frontend URL).
# Use * to allow any origin (not recommended for production).
CORS_ORIGIN="http://localhost:5173"

# Port the server listens on (Railway sets this; defaults to 8080).
PORT=8080
