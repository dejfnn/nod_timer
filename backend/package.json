{
  "name": "timeflow-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TimeFlow backend — Hono + Prisma + Postgres",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate",
    "start": "prisma migrate deploy && tsx src/index.ts",
    "migrate:dev": "prisma migrate dev",
    "studio": "prisma studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "hono": "^4.7.5",
    "tsx": "^4.19.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.10",
    "prisma": "^6.5.0",
    "typescript": "^5.8.2"
  }
}
